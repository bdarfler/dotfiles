#!/usr/bin/env python3
"""ss2epub — convert Substack newsletter HTML to a clean EPUB.

Strips email chrome (banner, byline/post-meta, READ IN APP button,
action icons, copyright + unsubscribe footer, subscriber bio block,
preview-pane spacer text) and inline email CSS, then runs pandoc.
Generates a typographic cover image with the title centered and
author/date stacked at the bottom.

Usage:
  ss2epub FILE.html [FILE.html ...]

Requires: pandoc and ImageMagick (brew install pandoc imagemagick).
"""

import argparse
import html as ihtml
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

HELVETICA = "/System/Library/Fonts/Helvetica.ttc"

FILTER_PATH = Path(__file__).resolve().parent / "ss2epub-filter.lua"


def extract_metadata(html_path: Path) -> dict[str, str]:
    """Pull title/author/date out of a Substack email HTML file."""
    h = html_path.read_text(encoding="utf-8", errors="replace")
    meta: dict[str, str] = {}

    def clean(s: str) -> str:
        return re.sub(r"\s+", " ", ihtml.unescape(s)).strip()

    m = re.search(r"<title>(.*?)</title>", h, re.S)
    if m:
        title = clean(m.group(1))
        if title:
            meta["title"] = title

    # Pandoc rejects full ISO timestamps in --metadata date=, so take the
    # YYYY-MM-DD prefix of <time datetime="...">.
    m = re.search(r'<time[^>]*datetime="([^"]+)"', h)
    if m:
        meta["date"] = m.group(1)[:10]

    pm = re.search(r'class="post-meta".*?</table>', h, re.S)
    if pm:
        a = re.search(
            r'<a[^>]+href="https://substack\.com/@[^"]+"[^>]*>([^<]+)</a>',
            pm.group(0),
        )
        if a:
            author = clean(a.group(1))
            if author:
                meta["author"] = author

    return meta


def render_cover(title: str, author: str, date: str, out_png: Path, tmpdir: Path) -> None:
    """Render the typographic cover PNG via ImageMagick."""
    title_txt = tmpdir / "title.txt"
    title_txt.write_text(title)

    args = [
        "magick",
        "-size", "1400x2100", "xc:white",
        "(",
            "-size", "1200x1400",
            "-background", "none",
            "-fill", "black",
            "-font", HELVETICA,
            "-gravity", "center",
            f"caption:@{title_txt}",
        ")",
        "-gravity", "center", "-composite",
        "-fill", "#555555",
        "-font", HELVETICA,
        "-gravity", "south",
    ]
    if author:
        args += ["-pointsize", "40", "-annotate", "+0+220", author]
    if date:
        args += ["-pointsize", "30", "-annotate", "+0+160", date]
    args.append(str(out_png))

    subprocess.run(args, check=True)


def convert(src: Path, tmpdir: Path) -> None:
    """Convert one Substack HTML file to an EPUB next to it."""
    if not src.is_file():
        print(f"ss2epub: not a file: {src}", file=sys.stderr)
        sys.exit(1)

    dest = src.with_suffix(".epub")
    meta = extract_metadata(src)

    # Pandoc's default EPUB stylesheet sets `h1 { page-break-before:
    # always }`, which renders as a blank page between the cover and
    # the post title in Apple Books. Inject an override after the
    # default stylesheet via --include-in-header so the default rules
    # still load and only the page-break rule loses.
    css_override = tmpdir / "override.html"
    css_override.write_text(
        "<style>h1 { page-break-before: avoid; }</style>\n"
    )

    pandoc_args = [
        "pandoc",
        str(src),
        "--lua-filter", str(FILTER_PATH),
        "--epub-title-page=false",
        f"--include-in-header={css_override}",
    ]
    for k, v in meta.items():
        pandoc_args += ["--metadata", f"{k}={v}"]

    if "title" in meta:
        cover_png = tmpdir / "cover.png"
        render_cover(
            meta["title"],
            meta.get("author", ""),
            meta.get("date", ""),
            cover_png,
            tmpdir,
        )
        pandoc_args.append(f"--epub-cover-image={cover_png}")

    pandoc_args += ["-o", str(dest)]
    subprocess.run(pandoc_args, check=True)
    print(f"wrote {dest}")


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="ss2epub",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "files",
        nargs="+",
        metavar="FILE.html",
        help="Substack newsletter HTML file(s) to convert.",
    )
    args = parser.parse_args()

    if not shutil.which("pandoc"):
        print("ss2epub: pandoc not found — brew install pandoc", file=sys.stderr)
        sys.exit(1)
    if not FILTER_PATH.is_file():
        print(f"ss2epub: lua filter not found at {FILTER_PATH}", file=sys.stderr)
        sys.exit(1)

    with tempfile.TemporaryDirectory(prefix="ss2epub-") as td:
        tmpdir = Path(td)
        for f in args.files:
            convert(Path(f), tmpdir)


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        # pandoc / magick already wrote their own error to stderr; just
        # propagate their exit code without dumping a Python traceback.
        sys.exit(e.returncode)
