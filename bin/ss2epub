#!/usr/bin/env python3
"""ss2epub — convert Substack newsletter HTML to a clean EPUB.

Strips email chrome (banner, byline/post-meta, READ IN APP button,
action icons, copyright + unsubscribe footer, subscriber bio block,
preview-pane spacer text) and inline email CSS, then runs pandoc.

Usage:
  ss2epub FILE.html [FILE.html ...]

Requires: pandoc (brew install pandoc).
"""

import argparse
import html as ihtml
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


FILTER_PATH = Path(__file__).resolve().parent / "ss2epub-filter.lua"

# FAT/NTFS reserved chars + ASCII control chars. Kindle's documents
# filesystem rejects these in titles and replaces them with `_` when it
# normalizes; pre-stripping here keeps titles clean downstream.
TITLE_STRIP_RE = re.compile(r'[<>:"/\\|?*\x00-\x1f]')


def sanitize_title(s: str) -> str:
    s = TITLE_STRIP_RE.sub("", s)
    return re.sub(r"\s+", " ", s).strip()


def extract_metadata(html_path: Path) -> dict[str, str]:
    """Pull title/author/date/description out of a Substack email HTML file."""
    h = html_path.read_text(encoding="utf-8", errors="replace")
    meta: dict[str, str] = {}

    def clean(s: str) -> str:
        return re.sub(r"\s+", " ", ihtml.unescape(s)).strip()

    m = re.search(r"<title>(.*?)</title>", h, re.S)
    if m:
        title = sanitize_title(clean(m.group(1)))
        if title:
            meta["title"] = title

    # Pandoc rejects full ISO timestamps in --metadata date=, so take the
    # YYYY-MM-DD prefix of <time datetime="...">.
    m = re.search(r'<time[^>]*datetime="([^"]+)"', h)
    if m:
        meta["date"] = m.group(1)[:10]

    pm = re.search(r'class="post-meta".*?</table>', h, re.S)
    if pm:
        a = re.search(
            r'<a[^>]+href="https://substack\.com/@[^"]+"[^>]*>([^<]+)</a>',
            pm.group(0),
        )
        if a:
            author = clean(a.group(1))
            if author:
                meta["author"] = author

    # Substack emits two <div class="preview"> blocks: the real subtitle
    # (the dek shown as the email preview) and a whitespace-padding block
    # of &#847;/&nbsp;/&#8199; entity refs. Strip tags + unescape first,
    # then pick the first match that contains any actual letter — the
    # padding block has none after unescape.
    for m in re.finditer(r'<div class="preview"[^>]*>(.*?)</div>', h, re.S):
        stripped = re.sub(r"<[^>]+>", "", m.group(1))
        cleaned = clean(stripped)
        if re.search(r"[A-Za-z]", cleaned):
            meta["description"] = cleaned
            break

    return meta


def convert(src: Path, tmpdir: Path) -> None:
    """Convert one Substack HTML file to an EPUB next to it."""
    if not src.is_file():
        print(f"ss2epub: not a file: {src}", file=sys.stderr)
        sys.exit(1)

    # Sanitize the output filename too — Kindle's library often uses the
    # filename (not dc:title) as the displayed title, so cleaning only
    # the metadata still leaves underscores in the reader UI.
    dest = src.with_suffix(".epub")
    clean_stem = sanitize_title(dest.stem)
    if clean_stem and clean_stem != dest.stem:
        dest = dest.parent / f"{clean_stem}.epub"

    if dest.exists():
        print(f"skipping {src}: {dest} already exists")
        return

    meta = extract_metadata(src)

    # Pandoc's default EPUB stylesheet sets `h1 { page-break-before:
    # always }`, which renders as a blank page before the post title.
    # Inject an override after the default stylesheet via
    # --include-in-header so the default rules still load and only the
    # page-break rule loses.
    css_override = tmpdir / "override.html"
    css_override.write_text(
        "<style>h1 { page-break-before: avoid; }</style>\n"
    )

    pandoc_args = [
        "pandoc",
        str(src),
        "--lua-filter", str(FILTER_PATH),
        "--epub-title-page=false",
        f"--include-in-header={css_override}",
    ]
    for k, v in meta.items():
        pandoc_args += ["--metadata", f"{k}={v}"]

    pandoc_args += ["-o", str(dest)]
    subprocess.run(pandoc_args, check=True)
    print(f"wrote {dest}")


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="ss2epub",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "files",
        nargs="+",
        metavar="FILE.html",
        help="Substack newsletter HTML file(s) to convert.",
    )
    args = parser.parse_args()

    if not shutil.which("pandoc"):
        print("ss2epub: pandoc not found — brew install pandoc", file=sys.stderr)
        sys.exit(1)
    if not FILTER_PATH.is_file():
        print(f"ss2epub: lua filter not found at {FILTER_PATH}", file=sys.stderr)
        sys.exit(1)

    with tempfile.TemporaryDirectory(prefix="ss2epub-") as td:
        tmpdir = Path(td)
        for f in args.files:
            convert(Path(f), tmpdir)


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        # pandoc already wrote its own error to stderr; just propagate
        # the exit code without dumping a Python traceback.
        sys.exit(e.returncode)
